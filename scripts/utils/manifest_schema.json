{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Imperial Scene Manifest",
  "description": "Schema for high-fidelity Blender scene generation at FGS Studio.",
  "type": "object",
  "properties": {
    "metadata": {
      "type": "object",
      "properties": {
        "project_name": { "type": "string" },
        "version": { "type": "string", "default": "1.0.0" },
        "author": { "type": "string" }
      },
      "required": ["project_name"]
    },
    "scene": {
      "type": "object",
      "properties": {
        "duration_seconds": { "type": "number", "minimum": 1 },
        "fps": { "type": "integer", "default": 24 },
        "engine": { "enum": ["EEVEE", "CYCLES"], "default": "EEVEE" }
      },
      "required": ["duration_seconds"]
    },
    "environment": {
      "type": "object",
      "properties": {
        "type": { "type": "string" },
        "params": { "type": "object" }
      },
      "required": ["type"]
    },
    "characters": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "name": { "type": "string" },
          "preset": { "type": "string" },
          "position": {
            "type": "array",
            "items": { "type": "number" },
            "minItems": 3,
            "maxItems": 3
          },
          "overrides": { "type": "object" }
        },
        "required": ["name", "preset"]
      }
    },
    "animations": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "target": { "type": "string" },
          "type": { "enum": ["head_bob", "risada", "rotation", "location", "orbitar", "caminhar"] },
          "start_frame": { "type": "integer" },
          "end_frame": { "type": "integer" },
          "params": { "type": "object" }
        },
        "required": ["target", "type"]
      }
    },
    "audio": {
      "type": "object",
      "properties": {
        "bgm": {
          "type": "object",
          "properties": {
            "path": { "type": "string" },
            "volume": { "type": "number" },
            "fade_in": { "type": "number" },
            "fade_out": { "type": "number" }
          },
          "required": ["path"]
        },
        "sfx": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "path": { "type": "string" },
              "frame": { "type": "integer" },
              "volume": { "type": "number" }
            },
            "required": ["path"]
          }
        }
      }
    }
  },
  "required": ["metadata", "scene", "characters"]
}
